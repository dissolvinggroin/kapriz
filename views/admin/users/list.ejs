<div class="adm-head"><h2>Пользователи <span>(<%= users.length %>)</span></h2></div>

<div class="adm-panel">
  <table class="adm-table">
    <thead><tr><th>Имя</th><th>Email</th><th>Роль</th><th>Регистрация</th></tr></thead>
    <tbody>
      <% users.forEach(function(u) { %>
        <tr>
          <td><%= u.name %></td>
          <td><%= u.email %></td>
          <td><span class="tag <%= u.role === 'admin' ? 'tag--hit' : '' %>"><%= u.role === 'admin' ? 'Админ' : 'Покупатель' %></span></td>
          <td><%= u.created_at.slice(0, 10) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
