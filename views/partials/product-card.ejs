<%
  var saved = (typeof wishlistIds !== 'undefined') && wishlistIds.has(product.id);
  var hasSale = product.sale_price && product.sale_price < product.price;
  var disc = hasSale ? discountPercent(product.price, product.sale_price) : 0;
  var colorList = splitCsv(product.colors).slice(0, 5);
  var stock = stockInfo(product.stock);
%>
<article class="card <%= stock.code === 'out' ? 'card--out' : '' %>">
  <div class="card__media">
    <a href="/catalog/<%= product.id %>" class="card__img-link">
      <img src="<%= product.image_url %>" alt="<%= product.name %>" loading="lazy" width="700" height="900"
           onerror="this.onerror=null;this.src='<%= imageFallback(product.id) %>'" />
    </a>
    <div class="card__badges">
      <% if (product.is_new) { %><span class="badge badge--new">Новинка</span><% } %>
      <% if (hasSale) { %><span class="badge badge--sale">−<%= disc %>%</span><% } %>
      <% if (stock.code === 'out') { %><span class="badge badge--out">Нет в наличии</span><% } else if (stock.code === 'low') { %><span class="badge badge--low">Мало</span><% } %>
    </div>
    <button class="wish-btn <%= saved ? 'is-active' : '' %>" data-id="<%= product.id %>"
            aria-label="В избранное" type="button">
      <svg viewBox="0 0 24 24" width="20" height="20"><path d="M12 21s-7.5-4.6-10-9.3C.4 8.4 2 5 5.4 5c2 0 3.3 1.1 4.1 2.3C10.3 6.1 11.6 5 13.6 5 17 5 18.6 8.4 17 11.7 14.5 16.4 12 21 12 21z"/></svg>
    </button>
  </div>
  <div class="card__body">
    <p class="card__cat"><%= product.category_name %></p>
    <h3 class="card__name"><a href="/catalog/<%= product.id %>"><%= product.name %></a></h3>
    <% if (colorList.length) { %>
      <div class="card__colors">
        <% colorList.forEach(function(c) { %>
          <span class="swatch" style="background: <%= colorHex(c) %>" title="<%= c %>"></span>
        <% }) %>
      </div>
    <% } %>
    <div class="card__foot">
      <div class="card__price">
        <% if (hasSale) { %>
          <span class="price price--sale"><%= formatPrice(product.sale_price) %></span>
          <span class="price price--old"><%= formatPrice(product.price) %></span>
        <% } else { %>
          <span class="price"><%= formatPrice(product.price) %></span>
        <% } %>
      </div>
      <% if (product.rating > 0) { %>
        <span class="card__rating"><%- include('stars', { value: product.rating }) %></span>
      <% } %>
    </div>
  </div>
</article>
