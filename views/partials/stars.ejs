<span class="stars" title="<%= value %> из 5">
  <% for (var s = 1; s <= 5; s++) { %>
    <svg viewBox="0 0 24 24" width="14" height="14" class="star <%= s <= Math.round(value) ? 'star--on' : '' %>">
      <path d="M12 2l2.9 6.3 6.8.6-5.1 4.5 1.5 6.7L12 17l-6 3.6 1.5-6.7L2.4 9l6.8-.6z" />
    </svg>
  <% } %>
</span>
