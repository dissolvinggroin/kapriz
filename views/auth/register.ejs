<section class="auth">
  <div class="auth__card">
    <h1 class="auth__title">Регистрация</h1>
    <p class="auth__sub">Создайте аккаунт и получите −10% на первый заказ</p>

    <% if (error) { %><p class="form-error"><%= error %></p><% } %>

    <form method="POST" action="/register" class="auth__form">
      <label>Имя<input type="text" name="name" value="<%= values.name || '' %>" required autofocus /></label>
      <label>Email<input type="email" name="email" value="<%= values.email || '' %>" required /></label>
      <label>Пароль<input type="password" name="password" required minlength="6" /></label>
      <label>Повторите пароль<input type="password" name="passwordConfirm" required minlength="6" /></label>
      <button type="submit" class="btn btn--accent btn--block btn--lg">Создать аккаунт</button>
    </form>

    <p class="auth__switch">Уже есть аккаунт? <a href="/login">Войти</a></p>
  </div>
</section>
