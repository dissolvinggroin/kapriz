<section class="container order-success">
  <div class="order-success__icon">
    <svg viewBox="0 0 24 24" width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/><path d="M8 12.5l2.5 2.5L16 9"/>
    </svg>
  </div>
  <h1>Спасибо за заказ!</h1>
  <p class="order-success__num">Номер заказа: <strong><%= orderNumber %></strong></p>
  <% if (typeof loggedIn !== 'undefined' && loggedIn) { %>
    <p class="order-success__text">Мы свяжемся с вами для уточнения деталей доставки. Статус заказа можно отслеживать в личном кабинете.</p>
    <div class="order-success__actions">
      <a href="/account" class="btn btn--accent btn--lg">Мои заказы</a>
      <a href="/catalog" class="btn btn--ghost btn--lg">Продолжить покупки</a>
    </div>
  <% } else { %>
    <p class="order-success__text">Мы свяжемся с вами для уточнения деталей доставки. Войдите в аккаунт, чтобы отслеживать статус заказов.</p>
    <div class="order-success__actions">
      <a href="/catalog" class="btn btn--accent btn--lg">Продолжить покупки</a>
      <a href="/login" class="btn btn--ghost btn--lg">Войти</a>
    </div>
  <% } %>
</section>
