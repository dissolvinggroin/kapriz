<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' · Каприз Admin' : 'Каприз Admin' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin.css?v=<%= assetVer %>" />
</head>
<body>
  <div class="adm">
    <aside class="adm__side">
      <a href="/" class="adm__logo">Каприз<span>admin</span></a>
      <nav class="adm__nav">
        <a href="/admin" class="<%= currentPath === '/admin' ? 'is-active' : '' %>"><%- include('../partials/icon', { name: 'dashboard', size: 18 }) %><span>Дашборд</span></a>
        <a href="/admin/products" class="<%= currentPath.indexOf('/admin/products') === 0 ? 'is-active' : '' %>"><%- include('../partials/icon', { name: 'bag', size: 18 }) %><span>Товары</span></a>
        <a href="/admin/orders" class="<%= currentPath.indexOf('/admin/orders') === 0 ? 'is-active' : '' %>"><%- include('../partials/icon', { name: 'box', size: 18 }) %><span>Заказы</span></a>
        <a href="/admin/categories" class="<%= currentPath.indexOf('/admin/categories') === 0 ? 'is-active' : '' %>"><%- include('../partials/icon', { name: 'folder', size: 18 }) %><span>Категории</span></a>
        <a href="/admin/reviews" class="<%= currentPath.indexOf('/admin/reviews') === 0 ? 'is-active' : '' %>"><%- include('../partials/icon', { name: 'star', size: 18 }) %><span>Отзывы</span></a>
        <a href="/admin/users" class="<%= currentPath.indexOf('/admin/users') === 0 ? 'is-active' : '' %>"><%- include('../partials/icon', { name: 'user', size: 18 }) %><span>Пользователи</span></a>
      </nav>
      <a href="/" class="adm__back">← На сайт</a>
    </aside>

    <div class="adm__main">
      <header class="adm__top">
        <strong><%= typeof title !== 'undefined' ? title : '' %></strong>
        <div class="adm__top-right">
          <span><%= currentUser.name %></span>
          <a href="/logout" class="adm__logout">Выйти</a>
        </div>
      </header>
      <main class="adm__content">
        <%- body %>
      </main>
    </div>
  </div>
</body>
</html>
