<section class="container cart-page">
  <nav class="crumbs"><a href="/">Главная</a> / <span>Корзина</span></nav>
  <h1 class="section__title">Корзина</h1>

  <% if (typeof checkoutError !== 'undefined' && checkoutError) { %>
    <p class="form-error"><%= checkoutError %></p>
  <% } %>

  <% if (!cart.items.length) { %>
    <div class="empty">
      <p>В корзине пока пусто.</p>
      <a href="/catalog" class="btn btn--accent btn--lg">Перейти в каталог</a>
    </div>
  <% } else { %>
    <div class="cart-layout">
      <div class="cart-list">
        <% cart.items.forEach(function(it) { %>
          <div class="cart-row">
            <a href="/catalog/<%= it.product.id %>" class="cart-row__img">
              <img src="<%= it.product.image_url %>" alt="<%= it.product.name %>"
                   onerror="this.onerror=null;this.src='<%= imageFallback(it.product.id) %>'" />
            </a>
            <div class="cart-row__info">
              <a href="/catalog/<%= it.product.id %>" class="cart-row__name"><%= it.product.name %></a>
              <p class="cart-row__meta">
                <%= it.product.category_name %>
                <% if (it.size) { %> · Размер: <strong><%= it.size %></strong><% } %>
                <% if (it.color) { %> · Цвет: <strong><%= it.color %></strong><% } %>
              </p>
              <p class="cart-row__unit"><%= formatPrice(it.unit) %> × <%= it.qty %></p>
            </div>
            <div class="cart-row__side">
              <form action="/cart/update" method="POST" class="qty-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="index" value="<%= it.index %>" />
                <label class="sr-only" for="qty<%= it.index %>">Количество</label>
                <input type="number" id="qty<%= it.index %>" name="qty" value="<%= it.qty %>" min="1" max="<%= Math.max(it.qty, it.product.stock) %>" />
                <button type="submit" class="btn btn--ghost btn--sm">Обновить</button>
              </form>
              <p class="cart-row__total"><%= formatPrice(it.lineTotal) %></p>
              <form action="/cart/remove" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="index" value="<%= it.index %>" />
                <button type="submit" class="link-remove">Удалить</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>

      <aside class="cart-summary">
        <h3>Итого</h3>
        <div class="cart-summary__row"><span>Товары (<%= cart.count %>)</span><span><%= formatPrice(cart.total) %></span></div>
        <div class="cart-summary__row"><span>Доставка</span><span><%= cart.total >= 5000 ? 'Бесплатно' : '300 ₽' %></span></div>
        <div class="cart-summary__total"><span>К оплате</span><strong><%= formatPrice(cart.total >= 5000 ? cart.total : cart.total + 300) %></strong></div>
        <form action="/cart/checkout" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn--accent btn--block btn--lg">Оформить заказ</button>
        </form>
        <p class="form-note">Оплата картой, СБП или при получении. Безопасная сделка.</p>
        <a href="/catalog" class="cart-summary__continue">← Продолжить покупки</a>
      </aside>
    </div>
  <% } %>
</section>
